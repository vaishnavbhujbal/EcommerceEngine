# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Supabase Postgres connection string (Project Settings → Database → Connection string → URI).
# Use the "Session" pooler or direct connection; must include ?sslmode=require for Supabase.
# Example shape (NOT a real credential):
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# OpenAI API key — used by ai.ts for embeddings (text-embedding-3-small) and chat (gpt-4o).
OPENAI_API_KEY=

# Port the Express API listens on.
PORT=4000
